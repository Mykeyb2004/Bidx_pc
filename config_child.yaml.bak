project:
  root_dir: /Users/zhangqijin/Documents/Field/项目数据库/2026/投标项目/蕲春民政困境儿童
  bidder_name: 菲尔德咨询
  inputs:
    outline_file: 投标大纲.md
    bid_requirements_file: 项目需求.md
    scoring_criteria_file: 评分标准.md
  output_dir: ./output
writing:
  target_words:
    default: 1500
    min: 100
    max: 12000
    step: 100
    upper_ratio: 1.15
  max_tables_per_section: 2
  max_mermaid_flowcharts_per_section: 1
  extra_rules: []
  role: "## 角色定位\n你是一位拥有20年从业经验的民政社会救助领域招投标专家，具有以下背景：\n1.  **学术高度：** 社会学/公共管理学博士，深谙社会救助政策顶层设计与理论逻辑。\n\
    2.  **机关深度：** 曾在省/市民政厅（局）政策研究室工作，负责文件起草、审核与项目评审，深知体制内文风与考核重点。\n3.  **基层广度：** 曾在街道/乡镇一线从事具体的低保核查与特困供养服务，处理过数千个案，熟知执行层面的痛点与难点。\n\
    你现在的核心任务是：**基于用户给定的标书大纲，结合招标需求与评分标准，撰写出合规、高分、可落地的投标文件。**\n\n## 核心工作流：三维响应机制\n\
    在接到任务时，必须严格执行以下“三合一”写作逻辑：\n**1. 骨架锁定：尊重[标书大纲]**\n*   **原则：** 用户的“标书大纲”是绝对指令。确保目录结构与招标文件完全一致，规避废标风险。\n\
    *   **动作：** 将你的输出内容完美填充进用户给定的章节框架中。\n**2. 血肉填充：响应[招标需求]**\n*   **原则：** “应答式”写作。用户提供的“采购需求”中的每一个指标（如服务人数、频次、时效），都必须在方案中转化为具体的承诺和执行措施。\n\
    *   **动作：** 将需求拆解为：服务目标 $\\rightarrow$ 实施步骤 $\\rightarrow$ 保障措施 $\\rightarrow$\
    \ 预期产出。\n**3. 灵魂注入：对标[评分标准]**\n*   **原则：** “拿分”是终极目标。仔细研读评分标准，识别高分关键词。\n*   **动作：**\n\
    \    *   若评分强调“针对性”：增加“本地化重难点分析”内容。\n    *   若评分强调“创新性”：植入“数字民政、主动发现机制、五社联动”等行业前沿概念。\n\
    \    *   若评分强调“团队配置”：着重描写社工师资质、督导体系与培训计划。"
processing:
  path: auto
  project_background:
    enabled: false
    max_chars: 800
    h2:
      precompute_on_batch: true
      generate_missing_on_single: true
      max_evidence_blocks: 6
      max_evidence_chars: 2400
      content_mode: excerpts
      min_evidence_blocks: 1
      fallback: raw_evidence
      cache_dir: ./caches/project_background_h2
  full_context:
    chapter_writing_plan:
      enabled: false
      max_chars: 320
  hybrid_extract:
    unavailable_policy: fail_fast
    scoring_parse_mode: auto
    scoring_max_rows: 4
    quote_only: true
    return_ids_only: true
    verify_max_candidates: 8
runtime:
  stream:
    enabled: true
    idle_timeout_seconds: 12
  trace:
    enabled: true
    directory: ./log/generation_traces
    mode: full
    write_prompt: true
    write_output: true
    write_context: true
    write_summary: true
    redact_sensitive: true
  debug:
    context_pruning_dump: true
  output:
    prefix: ''
    include_title_header: true
    overwrite_existing: true
    filename_max_length: 100
    empty_filename_fallback: 未命名
  merge:
    normalize_soft_line_breaks: true
fact_cards:
  enabled: true
  cards: []
  chapter_defaults: {}

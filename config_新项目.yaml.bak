project:
  root_dir: /Users/zhangqijin/Documents/Temp/标书生成
  bidder_name: 叉叉德
  outline_locked: true
  outline_generation:
    role_file: ./roles/标书架构师.md
  inputs:
    outline_file: /Users/zhangqijin/Documents/Temp/投标大纲.md
    bid_requirements_file: 采购需求.md
    scoring_criteria_file: 评分标准.md
  output_dir: ./output
writing:
  target_words:
    default: 1500
    min: 100
    max: 12000
    step: 100
    upper_ratio: 1.15
  max_tables_per_section: 2
  max_mermaid_flowcharts_per_section: 1
  extra_rules: []
  role_file: ./roles/通用投标角色.md
processing:
  path: auto
  scoring:
    enabled: true
  project_background:
    enabled: false
    max_chars: 800
    h2:
      precompute_on_batch: true
      generate_missing_on_single: true
      max_evidence_blocks: 6
      max_evidence_chars: 2400
      content_mode: excerpts
      min_evidence_blocks: 1
      fallback: raw_evidence
      cache_dir: ./caches/project_background_h2
  full_context:
    chapter_writing_plan:
      enabled: false
      max_chars: 320
  hybrid_extract:
    unavailable_policy: fail_fast
    scoring_parse_mode: auto
    scoring_max_rows: 4
    quote_only: true
    return_ids_only: true
    verify_max_candidates: 8
runtime:
  stream:
    enabled: true
    idle_timeout_seconds: 12
  trace:
    enabled: true
    directory: ./log/generation_traces
    mode: full
    write_prompt: true
    write_output: true
    write_context: true
    write_summary: true
    redact_sensitive: true
  debug:
    context_pruning_dump: true
  output:
    prefix: ''
    include_title_header: true
    overwrite_existing: true
    filename_max_length: 100
    empty_filename_fallback: 未命名
  merge:
    normalize_soft_line_breaks: true
fact_cards:
  enabled: true
  cards: []
  chapter_defaults:
    中国科学院上海光学精密机械研究所15号楼研究生公寓配套家具项目 > 6. 设计深化方案：空间场景效果图、产品配置与走线布置深化设计 > 6.3 3人间宿舍设计深化方案 > 6.3.1 3人间宿舍家具空间布局与产品配置方案:
      should_reference: false
      selections: []
    中国科学院上海光学精密机械研究所15号楼研究生公寓配套家具项目 > 6. 设计深化方案：空间场景效果图、产品配置与走线布置深化设计 > 6.3 3人间宿舍设计深化方案 > 6.3.2 3人间宿舍效果图方案一与视角一展示:
      should_reference: false
      selections: []
    中国科学院上海光学精密机械研究所15号楼研究生公寓配套家具项目 > 6. 设计深化方案：空间场景效果图、产品配置与走线布置深化设计 > 6.2 双人间宿舍设计深化方案 > 6.2.2 双人间宿舍效果图方案一与视角一展示:
      should_reference: false
      selections: []

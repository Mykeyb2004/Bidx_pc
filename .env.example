# Copy `.env.example` to `.env` for non-secret defaults,
# and keep the real API key in `.env.local`.

BID_WRITER_API_BASE_URL=https://api.openai.com/v1
BID_WRITER_MODEL=gpt-5.4
BID_WRITER_TEMPERATURE=0.7
BID_WRITER_MAX_TOKENS=10000
BID_WRITER_TIMEOUT_SECONDS=120
BID_WRITER_MAX_RETRIES=3
# BID_WRITER_TOP_P=0.95
# BID_WRITER_SEED=42
BID_WRITER_API_KEY=

# Optional: independent model for bid outline generation.
# Falls back to BID_WRITER_* when these are not set.
# BID_WRITER_OUTLINE_API_BASE_URL=https://api.openai.com/v1
# BID_WRITER_OUTLINE_API_KEY=
# BID_WRITER_OUTLINE_MODEL=gpt-5.4
# BID_WRITER_OUTLINE_TEMPERATURE=0.3
# BID_WRITER_OUTLINE_MAX_TOKENS=6000
# BID_WRITER_OUTLINE_TIMEOUT_SECONDS=120
# BID_WRITER_OUTLINE_MAX_RETRIES=3
# BID_WRITER_OUTLINE_TOP_P=0.95
# BID_WRITER_OUTLINE_SEED=42

# Optional: independent model for chapter context pruning / brief generation.
# Keep real secrets in `.env.local`.
# BID_WRITER_PRUNING_API_BASE_URL=https://api.openai.com/v1
# BID_WRITER_PRUNING_MODEL=gpt-5.4
# BID_WRITER_PRUNING_TEMPERATURE=0.2
# BID_WRITER_PRUNING_MAX_TOKENS=1200
# BID_WRITER_PRUNING_TIMEOUT_SECONDS=60
# BID_WRITER_PRUNING_MAX_RETRIES=2
# BID_WRITER_PRUNING_TOP_P=0.95
# BID_WRITER_PRUNING_SEED=42
# BID_WRITER_PRUNING_API_KEY=

# Optional: advanced auto-mode requirement retrieval knobs.
# Usually keep these defaults; put overrides in `.env.local` when needed.
# BID_WRITER_AUTO_REQUIREMENTS_TOP_K=8
# BID_WRITER_AUTO_RETRIEVAL_LEXICAL_ENABLED=true
# BID_WRITER_AUTO_RETRIEVAL_VECTOR_ENABLED=false
# BID_WRITER_AUTO_RETRIEVAL_TOP_K_LEXICAL=20
# BID_WRITER_AUTO_RETRIEVAL_TOP_K_VECTOR=20
# BID_WRITER_AUTO_RETRIEVAL_TOP_K_FUSED=30
# BID_WRITER_AUTO_RETRIEVAL_TOP_K_FINAL=8
# BID_WRITER_AUTO_RETRIEVAL_MIN_FUSED_SCORE=0.0

# Optional: embedding service for vector retrieval.
# Keep real secrets in `.env.local`.
# Use the service root path such as `https://api.openai.com/v1`,
# not the final `/embeddings` endpoint path.
# BID_WRITER_EMBEDDING_API_BASE_URL=https://api.openai.com/v1
# BID_WRITER_EMBEDDING_API_KEY=
# BID_WRITER_EMBEDDING_MODEL=text-embedding-3-large
# BID_WRITER_EMBEDDING_BATCH_SIZE=64
# BID_WRITER_EMBEDDING_REBUILD_ON_SOURCE_CHANGE=true
# BID_WRITER_EMBEDDING_QUERY_PREFIX=
# BID_WRITER_EMBEDDING_DOCUMENT_PREFIX=
